{
  "name": "@ensdomains/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "ens": "dist/ens.mjs"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/ens.mjs --target node --minify",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "files": ["dist"],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "@types/bun": "latest",
    "incur": "^0.4.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "viem": "^2.47.6",
    "wrangler": "^4.0.0"
  }
}
