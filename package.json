{
  "name": "@ensdomains/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "ens": "dist/ens.mjs"
  },
  "packageManager": "bun@1.3.6",
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/ens.mjs --target node --minify",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260611.1",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "@types/bun": "1.3.14",
    "incur": "0.4.8",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "viem": "2.52.2",
    "wrangler": "4.100.0"
  }
}
